<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Daisy"
  targetNamespace="http://example.com/daisy-bpmn">

  <bpmn:process id="Process_Daisy_MaterialRecovery" name="Apple-style iPhone Material Recovery (incl. Daisy line)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Collection" name="Collection &amp; Triage">
        <bpmn:flowNodeRef>StartEvent_DeviceReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IntakeRegister</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReuseDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RouteToRefurb</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SortForMaterialRecovery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IdentifyModel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SupportedByDaisy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RouteAlternativeTreatment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Reused</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AltRecovered</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Human" name="Human operator &amp; safety">
        <bpmn:flowNodeRef>Task_FeedIntoDaisy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_BatteryIssue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManualBatteryHandling</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CollectBins</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PackAndLabel</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Daisy" name="Daisy line (automated modules)">
        <bpmn:flowNodeRef>Task_Module1_OpenAndSeparateDisplay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Module2_CoolAndRemoveBattery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Module3_PunchOutModules</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Module4_ScreenAndPreSort</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Downstream" name="Downstream recyclers / refiners">
        <bpmn:flowNodeRef>Gateway_SplitShipments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipBatteries</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipLogicBoards</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipMagnetsModules</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShipAluminumHousings</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JoinShipments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_FractionsDelivered</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Flow nodes -->
    <bpmn:startEvent id="StartEvent_DeviceReceived" name="Device received" />

    <bpmn:task id="Task_IntakeRegister" name="Register intake / basic inspection" />

    <bpmn:exclusiveGateway id="Gateway_ReuseDecision" name="Suitable for reuse?" />

    <bpmn:task id="Task_RouteToRefurb" name="Route to refurbishment / resale" />
    <bpmn:endEvent id="EndEvent_Reused" name="Reused (exit)" />

    <bpmn:task id="Task_SortForMaterialRecovery" name="Sort for material recovery" />
    <bpmn:task id="Task_IdentifyModel" name="Identify device model" />

    <bpmn:exclusiveGateway id="Gateway_SupportedByDaisy" name="Supported by Daisy?" />

    <bpmn:task id="Task_RouteAlternativeTreatment" name="Route to alternative treatment (manual / other)" />
    <bpmn:endEvent id="EndEvent_AltRecovered" name="Recovered via other process (exit)" />

    <bpmn:task id="Task_FeedIntoDaisy" name="Feed device into Daisy infeed" />

    <bpmn:task id="Task_Module1_OpenAndSeparateDisplay" name="Module 1: Open device &amp; separate display" />

    <bpmn:task id="Task_Module2_CoolAndRemoveBattery" name="Module 2: Cool to weaken adhesive &amp; remove battery" />
    <bpmn:boundaryEvent id="BoundaryEvent_BatteryIssue" name="Battery issue" attachedToRef="Task_Module2_CoolAndRemoveBattery" cancelActivity="true">
      <bpmn:escalationEventDefinition />
    </bpmn:boundaryEvent>

    <bpmn:task id="Task_ManualBatteryHandling" name="Manual safe handling / isolate battery" />

    <bpmn:task id="Task_Module3_PunchOutModules" name="Module 3: Punch out screws &amp; modules" />
    <bpmn:task id="Task_Module4_ScreenAndPreSort" name="Module 4: Screen / pre-sort parts" />

    <bpmn:task id="Task_CollectBins" name="Collect separated components into bins" />
    <bpmn:task id="Task_PackAndLabel" name="Pack fractions / label for shipment" />

    <bpmn:parallelGateway id="Gateway_SplitShipments" name="Split shipments" />
    <bpmn:task id="Task_ShipBatteries" name="Ship batteries to battery recycler" />
    <bpmn:task id="Task_ShipLogicBoards" name="Ship logic boards to precious-metal refiner" />
    <bpmn:task id="Task_ShipMagnetsModules" name="Ship magnets / modules to rare-earth recycler" />
    <bpmn:task id="Task_ShipAluminumHousings" name="Ship aluminum housings to smelter" />
    <bpmn:parallelGateway id="Gateway_JoinShipments" name="All shipments dispatched" />

    <bpmn:endEvent id="EndEvent_FractionsDelivered" name="Fractions delivered (end)" />

    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_DeviceReceived" targetRef="Task_IntakeRegister" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_IntakeRegister" targetRef="Gateway_ReuseDecision" />

    <bpmn:sequenceFlow id="Flow_3_yes" sourceRef="Gateway_ReuseDecision" targetRef="Task_RouteToRefurb" name="Yes" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_RouteToRefurb" targetRef="EndEvent_Reused" />

    <bpmn:sequenceFlow id="Flow_3_no" sourceRef="Gateway_ReuseDecision" targetRef="Task_SortForMaterialRecovery" name="No" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_SortForMaterialRecovery" targetRef="Task_IdentifyModel" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_IdentifyModel" targetRef="Gateway_SupportedByDaisy" />

    <bpmn:sequenceFlow id="Flow_7_yes" sourceRef="Gateway_SupportedByDaisy" targetRef="Task_FeedIntoDaisy" name="Yes" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_FeedIntoDaisy" targetRef="Task_Module1_OpenAndSeparateDisplay" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Module1_OpenAndSeparateDisplay" targetRef="Task_Module2_CoolAndRemoveBattery" />

    <!-- Normal path continues after battery removal -->
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_Module2_CoolAndRemoveBattery" targetRef="Task_Module3_PunchOutModules" />

    <!-- Exception path via boundary escalation -->
    <bpmn:sequenceFlow id="Flow_10b" sourceRef="BoundaryEvent_BatteryIssue" targetRef="Task_ManualBatteryHandling" />
    <bpmn:sequenceFlow id="Flow_10c" sourceRef="Task_ManualBatteryHandling" targetRef="Task_Module3_PunchOutModules" />

    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_Module3_PunchOutModules" targetRef="Task_Module4_ScreenAndPreSort" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Module4_ScreenAndPreSort" targetRef="Task_CollectBins" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_CollectBins" targetRef="Task_PackAndLabel" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_PackAndLabel" targetRef="Gateway_SplitShipments" />

    <bpmn:sequenceFlow id="Flow_15a" sourceRef="Gateway_SplitShipments" targetRef="Task_ShipBatteries" />
    <bpmn:sequenceFlow id="Flow_15b" sourceRef="Gateway_SplitShipments" targetRef="Task_ShipLogicBoards" />
    <bpmn:sequenceFlow id="Flow_15c" sourceRef="Gateway_SplitShipments" targetRef="Task_ShipMagnetsModules" />
    <bpmn:sequenceFlow id="Flow_15d" sourceRef="Gateway_SplitShipments" targetRef="Task_ShipAluminumHousings" />

    <bpmn:sequenceFlow id="Flow_16a" sourceRef="Task_ShipBatteries" targetRef="Gateway_JoinShipments" />
    <bpmn:sequenceFlow id="Flow_16b" sourceRef="Task_ShipLogicBoards" targetRef="Gateway_JoinShipments" />
    <bpmn:sequenceFlow id="Flow_16c" sourceRef="Task_ShipMagnetsModules" targetRef="Gateway_JoinShipments" />
    <bpmn:sequenceFlow id="Flow_16d" sourceRef="Task_ShipAluminumHousings" targetRef="Gateway_JoinShipments" />

    <bpmn:sequenceFlow id="Flow_17" sourceRef="Gateway_JoinShipments" targetRef="EndEvent_FractionsDelivered" />

    <bpmn:sequenceFlow id="Flow_7_no" sourceRef="Gateway_SupportedByDaisy" targetRef="Task_RouteAlternativeTreatment" name="No" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_RouteAlternativeTreatment" targetRef="EndEvent_AltRecovered" />

  </bpmn:process>

  <!-- Diagram Interchange (layout) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Daisy_MaterialRecovery">

      <!-- Lane shapes -->
      <bpmndi:BPMNShape id="LaneShape_Collection" bpmnElement="Lane_Collection" isHorizontal="true">
        <dc:Bounds x="80" y="60" width="1520" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneShape_Human" bpmnElement="Lane_Human" isHorizontal="true">
        <dc:Bounds x="80" y="230" width="1520" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneShape_Daisy" bpmnElement="Lane_Daisy" isHorizontal="true">
        <dc:Bounds x="80" y="380" width="1520" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneShape_Downstream" bpmnElement="Lane_Downstream" isHorizontal="true">
        <dc:Bounds x="80" y="530" width="1520" height="170" />
      </bpmndi:BPMNShape>

      <!-- Node shapes -->
      <bpmndi:BPMNShape id="Shape_StartEvent_DeviceReceived" bpmnElement="StartEvent_DeviceReceived">
        <dc:Bounds x="120" y="115" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_IntakeRegister" bpmnElement="Task_IntakeRegister">
        <dc:Bounds x="190" y="95" width="190" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_ReuseDecision" bpmnElement="Gateway_ReuseDecision" isMarkerVisible="true">
        <dc:Bounds x="420" y="108" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_RouteToRefurb" bpmnElement="Task_RouteToRefurb">
        <dc:Bounds x="520" y="75" width="210" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_Reused" bpmnElement="EndEvent_Reused">
        <dc:Bounds x="760" y="95" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_SortForMaterialRecovery" bpmnElement="Task_SortForMaterialRecovery">
        <dc:Bounds x="520" y="145" width="210" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_IdentifyModel" bpmnElement="Task_IdentifyModel">
        <dc:Bounds x="760" y="145" width="190" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_SupportedByDaisy" bpmnElement="Gateway_SupportedByDaisy" isMarkerVisible="true">
        <dc:Bounds x="985" y="158" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_RouteAlternativeTreatment" bpmnElement="Task_RouteAlternativeTreatment">
        <dc:Bounds x="1080" y="145" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_AltRecovered" bpmnElement="EndEvent_AltRecovered">
        <dc:Bounds x="1370" y="165" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_FeedIntoDaisy" bpmnElement="Task_FeedIntoDaisy">
        <dc:Bounds x="1080" y="255" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Module1" bpmnElement="Task_Module1_OpenAndSeparateDisplay">
        <dc:Bounds x="1080" y="405" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Module2" bpmnElement="Task_Module2_CoolAndRemoveBattery">
        <dc:Bounds x="1360" y="405" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_BoundaryEvent_BatteryIssue" bpmnElement="BoundaryEvent_BatteryIssue">
        <dc:Bounds x="1500" y="470" width="30" height="30" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ManualBatteryHandling" bpmnElement="Task_ManualBatteryHandling">
        <dc:Bounds x="1360" y="255" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Module3" bpmnElement="Task_Module3_PunchOutModules">
        <dc:Bounds x="1640" y="405" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Module4" bpmnElement="Task_Module4_ScreenAndPreSort">
        <dc:Bounds x="1920" y="405" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_CollectBins" bpmnElement="Task_CollectBins">
        <dc:Bounds x="1920" y="255" width="260" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_PackAndLabel" bpmnElement="Task_PackAndLabel">
        <dc:Bounds x="2200" y="255" width="240" height="76" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_SplitShipments" bpmnElement="Gateway_SplitShipments" isMarkerVisible="true">
        <dc:Bounds x="2465" y="603" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ShipBatteries" bpmnElement="Task_ShipBatteries">
        <dc:Bounds x="2560" y="545" width="240" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ShipLogicBoards" bpmnElement="Task_ShipLogicBoards">
        <dc:Bounds x="2560" y="615" width="240" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ShipMagnetsModules" bpmnElement="Task_ShipMagnetsModules">
        <dc:Bounds x="2820" y="545" width="270" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ShipAluminumHousings" bpmnElement="Task_ShipAluminumHousings">
        <dc:Bounds x="2820" y="615" width="270" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_JoinShipments" bpmnElement="Gateway_JoinShipments" isMarkerVisible="true">
        <dc:Bounds x="3115" y="603" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_FractionsDelivered" bpmnElement="EndEvent_FractionsDelivered">
        <dc:Bounds x="3210" y="615" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="Edge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="156" y="133" />
        <di:waypoint x="190" y="133" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="380" y="133" />
        <di:waypoint x="420" y="133" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_3_yes" bpmnElement="Flow_3_yes">
        <di:waypoint x="470" y="133" />
        <di:waypoint x="520" y="113" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint x="730" y="113" />
        <di:waypoint x="760" y="113" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_3_no" bpmnElement="Flow_3_no">
        <di:waypoint x="470" y="133" />
        <di:waypoint x="520" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_5" bpmnElement="Flow_5">
        <di:waypoint x="730" y="183" />
        <di:waypoint x="760" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_6" bpmnElement="Flow_6">
        <di:waypoint x="950" y="183" />
        <di:waypoint x="985" y="183" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_7_no" bpmnElement="Flow_7_no">
        <di:waypoint x="1035" y="183" />
        <di:waypoint x="1080" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_18" bpmnElement="Flow_18">
        <di:waypoint x="1340" y="183" />
        <di:waypoint x="1370" y="183" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_7_yes" bpmnElement="Flow_7_yes">
        <di:waypoint x="1035" y="183" />
        <di:waypoint x="1080" y="293" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_8" bpmnElement="Flow_8">
        <di:waypoint x="1340" y="293" />
        <di:waypoint x="1080" y="443" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_9" bpmnElement="Flow_9">
        <di:waypoint x="1340" y="443" />
        <di:waypoint x="1360" y="443" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_10" bpmnElement="Flow_10">
        <di:waypoint x="1620" y="443" />
        <di:waypoint x="1640" y="443" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_10b" bpmnElement="Flow_10b">
        <di:waypoint x="1515" y="500" />
        <di:waypoint x="1490" y="293" />
        <di:waypoint x="1360" y="293" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_10c" bpmnElement="Flow_10c">
        <di:waypoint x="1620" y="293" />
        <di:waypoint x="1770" y="293" />
        <di:waypoint x="1770" y="405" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_11" bpmnElement="Flow_11">
        <di:waypoint x="1900" y="443" />
        <di:waypoint x="1920" y="443" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_12" bpmnElement="Flow_12">
        <di:waypoint x="2180" y="443" />
        <di:waypoint x="2050" y="331" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_13" bpmnElement="Flow_13">
        <di:waypoint x="2180" y="293" />
        <di:waypoint x="2200" y="293" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_14" bpmnElement="Flow_14">
        <di:waypoint x="2440" y="293" />
        <di:waypoint x="2490" y="603" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_15a" bpmnElement="Flow_15a">
        <di:waypoint x="2515" y="628" />
        <di:waypoint x="2560" y="575" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_15b" bpmnElement="Flow_15b">
        <di:waypoint x="2515" y="628" />
        <di:waypoint x="2560" y="645" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_15c" bpmnElement="Flow_15c">
        <di:waypoint x="2515" y="628" />
        <di:waypoint x="2820" y="575" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_15d" bpmnElement="Flow_15d">
        <di:waypoint x="2515" y="628" />
        <di:waypoint x="2820" y="645" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_16a" bpmnElement="Flow_16a">
        <di:waypoint x="2800" y="575" />
        <di:waypoint x="3115" y="628" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_16b" bpmnElement="Flow_16b">
        <di:waypoint x="2800" y="645" />
        <di:waypoint x="3115" y="628" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_16c" bpmnElement="Flow_16c">
        <di:waypoint x="3090" y="575" />
        <di:waypoint x="3115" y="628" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_16d" bpmnElement="Flow_16d">
        <di:waypoint x="3090" y="645" />
        <di:waypoint x="3115" y="628" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_17" bpmnElement="Flow_17">
        <di:waypoint x="3165" y="628" />
        <di:waypoint x="3210" y="633" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
